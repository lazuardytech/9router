{
  "name": "pod",
  "version": "0.0.12",
  "description": "Pod web dashboard",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --bun next dev --webpack --port 20128",
    "build": "NODE_ENV=production bun --bun next build --webpack",
    "start": "NODE_ENV=production bun ./.next/standalone/server.js",
    "format": "biome format --write .",
    "check": "biome format --write . && biome lint . && bun x eslint . || true",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "confbox": "^0.2.4",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.1.3",
    "lowdb": "^7.0.1",
    "marked": "^18.0.1",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.6",
    "node-forge": "^1.3.3",
    "node-machine-id": "^1.1.12",
    "open": "^11.0.0",
    "ora": "^9.1.0",
    "prop-types": "^15.8.1",
    "proper-lockfile": "^4.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^16.13.1",
    "recharts": "^3.7.0",
    "selfsigned": "^5.5.0",
    "socks-proxy-agent": "^8.0.5",
    "sonner": "^2.0.3",
    "sql.js": "^1.14.1",
    "undici": "^7.19.2",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.2.4",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "trustedDependencies": [
    "better-sqlite3"
  ]
}
